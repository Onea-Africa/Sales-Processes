# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb://localhost:27017/onea-africa

# Server
PORT=4000
CLIENT_ORIGIN=https://www.onea.africa

# JWT (use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Admin login for /api/auth/login
ADMIN_EMAIL=neo@onea.co.za
ADMIN_PASSWORD=replace-with-secure-password

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret-key
# Public site key (used in frontend): 6LdbH-MsAAAAAPHjXb5egDONWDxWE_nZPj7qW464

# SMTP for email notifications to sales@oea.o.za
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=sales@oea.o.za
SMTP_PASS=your-smtp-password

# Google Sheets (optional — for sheet-based lead logging)
GOOGLE_SHEETS_ID=replace-with-google-sheets-id
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
