{
    "name": "ceo-dashboard",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "concurrently --names FE,API --prefix-colors cyan,green \"vite\" \"npm run server\"",
        "server": "cd server && node index.js",
        "build": "tsc && vite build --outDir dist-ready && node scripts/prerender-static-routes.mjs dist-ready && node scripts/sync-dist-output.mjs",
        "preview": "vite preview",
        "icons": "node scripts/generate-icons.mjs",
        "prerender:seo": "node scripts/prerender-static-routes.mjs",
        "sync:dist": "node scripts/sync-dist-output.mjs",
        "pricing:sync": "node scripts/sync-pricing-rate-card.mjs",
        "pricing:apple-cache": "node scripts/build-apple-public-cache.mjs",
        "test:pricing": "node scripts/validate-pricing.mjs",
        "test:sendmail": "node scripts/test-sendmail.js",
        "import:telkom": "node scripts/import-telkom.mjs"
    },
    "dependencies": {
        "framer-motion": "^12.38.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^3.0.0",
        "react-router-dom": "^7.15.0",
        "recharts": "^2.8.0"
    },
    "devDependencies": {
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.5.0",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.14",
        "sharp": "^0.34.5",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.6.0",
        "vite": "^5.4.1",
        "xlsx": "^0.18.5"
    }
}
