Options -MultiViews
RewriteEngine On
RewriteBase /

# Force HTTPS first so search engines only see the secure canonical version
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://onea.africa%{REQUEST_URI} [R=301,L]

# Canonical host: keep all public URLs on non-www onea.africa
RewriteCond %{HTTP_HOST} ^www\.onea\.africa$ [NC]
RewriteRule ^ https://onea.africa%{REQUEST_URI} [R=301,L]

# Remove trailing slashes from page URLs while preserving real directories.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{THE_REQUEST} \s/+(.+?)/+[?\s] [NC]
RewriteRule ^(.+?)/+$ /$1 [R=301,L,NE]

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), browsing-topics=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google.com https://www.gstatic.com https://www.clarity.ms https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com https://www.clarity.ms https://*.clarity.ms https://connect.facebook.net https://www.facebook.com; frame-src 'self' https://www.googletagmanager.com https://www.google.com https://recaptcha.google.com;"

  <FilesMatch "\.(?:css|js|mjs|woff2?|webp|png|jpe?g|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html?)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

<FilesMatch "(^\.env|\.log$|\.jsonl$|\.lock$|service-account.*\.json$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Legacy public URLs from the previous site
RewriteRule ^about/?$ /team [R=301,L]
RewriteRule ^contact/?$ / [R=301,L]
RewriteRule ^client-login/?$ /client-portal [R=301,L]
RewriteRule ^improve-how-you-present-your-brandblog/?$ /blog [R=301,L]

# React route that conflicts with the physical /team image directory
RewriteRule ^team/?$ /index.html [QSA,L]

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Never rewrite missing build assets to the SPA document.
# A missing JavaScript file served as text/html leaves the app blank.
RewriteRule \.(?:css|js|mjs|map|json|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|tsx?)$ - [R=404,L,NC]

# Known public React routes
RewriteRule ^(?:|connectivity|solutions|pricing|apple-device-procurement|telkom-application|client-portal|team|careers|blog|case-studies|privacy|terms)/?$ index.html [QSA,L]
RewriteRule ^solutions/(?:openserve-business-fibre|lte-enterprise-packages|home-wifi-networking|managed-it-support|corporate-digital-marketing)/?$ index.html [QSA,L]

# Valid dynamic and authenticated React route families
RewriteRule ^(?:blog|case-studies)/[^/]+/?$ index.html [QSA,L]
RewriteRule ^telkom-sign/[^/]+/?$ index.html [QSA,L]
RewriteRule ^launch-platform(?:/.*)?$ index.html [QSA,L]

# Unknown routes must return a real HTTP 404 rather than a soft-404 SPA page.
RewriteRule ^ - [R=404,L]
